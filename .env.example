# Server
PORT=3002
NODE_ENV=development

# YouTube Data API v3
YOUTUBE_API_KEY=

# Admin
ADMIN_PASSWORD=changeme

# Session
SESSION_SECRET=changeme-random-string

# YouTube playlist ID used as idle filler when queue is empty
# Lo-Fi Hip Hop default — replace with your own playlist ID later
FILLER_PLAYLIST_ID=PLOzDu-MXXLliO9fBNZOQTBDddoA3FzZUo

# Livestream (Owncast HLS output)
RIGO_LIVESTREAM_URL=https://radio.mydomain.com/hls/stream.m3u8
RIGO_LIVESTREAM_STATUS_URL=https://radio.mydomain.com/api/status

# Token für VDJ→Rigo Live Now-Playing-Posts (frei wählbar, sollte geheim sein)
RIGO_VDJ_TOKEN=
